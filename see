#!/bin/bash
python3 - << 'PYEOF'
import sqlite3, json
conn = sqlite3.connect('/home/ec2-user/op.db')
rows = conn.execute('''
    SELECT id, original_filename, taken_at, album, caption,
           geo_lat, geo_lon, camera_make, camera_model,
           width, height, media_type
    FROM media ORDER BY taken_at DESC LIMIT 10
''').fetchall()
for r in rows:
    print(json.dumps({
        'id': r[0], 'file': r[1], 'taken': r[2], 'album': r[3],
        'caption': r[4], 'lat': r[5], 'lon': r[6],
        'camera': f"{r[7]} {r[8]}", 'size': f"{r[9]}x{r[10]}",
        'type': r[11]
    }, indent=2))
PYEOF

